# =============================================================================
# .envrc — direnv auto-loader for the FlexNetOS umbrella repo
# =============================================================================
# When you `cd` into this repo, direnv reads this file and exports the
# variables. When you `cd` out, they're unloaded. First-time setup:
#
#     sudo apt-get install -y direnv
#     echo 'eval "$(direnv hook bash)"' >> ~/.bashrc        # or zsh equiv
#     cd /path/to/my-github
#     direnv allow            # required after every edit to this file
#
# The .envrc is checked into git; it does NOT contain secrets. Secrets
# come from `pass` (see secrets/README.md) — this file just wires them up.
# =============================================================================

# Resolve the pass store to this repo's secrets/store
export PASSWORD_STORE_DIR="${PWD}/secrets/store"

# Helper: export $1 = `pass show $2`, but silently no-op if pass or the
# entry isn't available yet (avoids breaking fresh clones).
use_pass() {
    local var="$1" entry="$2"
    if command -v pass >/dev/null 2>&1 && [ -d "$PASSWORD_STORE_DIR" ]; then
        if pass show "$entry" >/dev/null 2>&1; then
            export "$var=$(pass show "$entry")"
        fi
    fi
}

# Helper: expand a `pass:<entry>` placeholders file. Lines like
#   FOO=pass:bar/baz
# become `export FOO=$(pass show bar/baz)`. Lines without `pass:` are
# exported as-is. Comments and blank lines pass through.
expand_env_template() {
    local tmpl="$1"
    [ -f "$tmpl" ] || return 0
    while IFS= read -r line; do
        case "$line" in
            ''|'#'*) continue ;;
            *=pass:*)
                local k="${line%%=*}"
                local entry="${line#*=pass:}"
                use_pass "$k" "$entry"
                ;;
            *=*)
                export "$line"
                ;;
        esac
    done < "$tmpl"
}

# Load the dev env template — populates OPENAI_API_KEY, GITHUB_TOKEN, etc.
expand_env_template "${PWD}/secrets/envs/dev.env.tmpl"

# Repository-local PATH so scripts/ are first-class
PATH_add "${PWD}/scripts"
PATH_add "${PWD}/runner"
