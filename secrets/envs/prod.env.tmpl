# =============================================================================
# Prod environment template
# =============================================================================
# Intentionally sparse. Production secrets live in runtime-injected stores
# (cloud provider's secret manager, Kubernetes secrets, etc.) — NOT here.
#
# This file documents the env-var contract so deployments can validate
# they have everything they need before starting.
# =============================================================================

# --- Required at runtime; injected by the deployment platform ---
DATABASE_URL=__INJECTED_AT_RUNTIME__
REDIS_URL=__INJECTED_AT_RUNTIME__

# --- Observability ---
SENTRY_DSN=__INJECTED_AT_RUNTIME__
OTEL_EXPORTER_OTLP_ENDPOINT=__INJECTED_AT_RUNTIME__

# --- Non-secret config ---
NODE_ENV=production
RUST_LOG=warn
