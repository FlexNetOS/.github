# =============================================================================
# Dev environment template
# =============================================================================
# `direnv` reads /.envrc which sources this template through the
# `use_pass_template` helper. Placeholders of the form `pass:<entry>`
# get expanded by shelling out to `pass show <entry>` at load time.
#
# Comment lines (#) and blank lines are passed through unchanged.
# Lines without `pass:` are exported as-is (useful for non-secret config).
#
# Edit freely. Restart the shell or `direnv reload` to re-apply.
# =============================================================================

# --- API keys ---
OPENAI_API_KEY=pass:openai/personal
ANTHROPIC_API_KEY=pass:anthropic/personal
HF_TOKEN=pass:hf/personal
GITHUB_TOKEN=pass:github/personal/cli

# --- Non-secret config ---
WIKI_ROOT=./wiki
WIKI_LOG=./wiki/log.md
MANIFEST=./repos/MANIFEST.yaml

# --- Toggles (not secrets, just convenient to centralize) ---
RUST_LOG=info
NODE_ENV=development
