# =============================================================================
# CI environment template — for the self-hosted runner
# =============================================================================
# Only RUNNER-scoped secrets here. Anything under store/personal/ MUST NOT
# appear in this file — that would leak personal secrets to CI jobs.
#
# The reusable workflow `reusable-secrets.yml` reads this template, expands
# `pass:` placeholders, and writes them to $GITHUB_ENV.
# =============================================================================

# --- Registry / deploy ---
DOCKERHUB_USER=pass:runner/dockerhub/user
DOCKERHUB_TOKEN=pass:runner/dockerhub/token
GHCR_TOKEN=pass:runner/ghcr/token

# --- Code scanning + signing ---
COSIGN_KEY=pass:runner/cosign/key
COSIGN_PASSWORD=pass:runner/cosign/password

# --- Non-secret config ---
CI=true
NODE_ENV=production
RUST_LOG=warn
